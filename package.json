{
  "name": "@asghonim/supabase-js",
  "version": "0.3.0-alpha.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/asghonim/supabase-js"
  },
  "description": "Supabase JS client",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "manifest.json",
    "src/commands/add.js",
    "supabase/migrations"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "supabase",
    "javascript",
    "typescript"
  ],
  "author": "asghonim",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "next": "16.1.6"
  },
  "bin": "./bin/cli.js",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "peerDependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "next": "16.1.6"
  }
}