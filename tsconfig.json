{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2019"],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "types": [
      "node"
    ],
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
